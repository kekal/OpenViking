{
  "storage": {
    "workspace": "/path/to/openviking/workspace"
  },
  "log": {
    "level": "INFO",
    "output": "stdout"
  },
  "embedding": {
    "dense": {
      "provider": "ollama",
      "model": "nomic-embed-text",
      "api_base": "http://localhost:11434/v1",
      "dimension": 768
    },
    "max_concurrent": 10
  },
  "vlm": {
    "provider": "claude-code",
    "model": "claude-sonnet-4-6",
    "max_concurrent": 10
  },
  "semantic": {
    "abstract_max_chars": 512,
    "overview_max_chars": 8000
  }
}
